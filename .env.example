# Copy this file to .env and fill in real values. Never commit .env.

# PostgreSQL password (used by docker-compose)
POSTGRES_PASSWORD=changeme

# Full async DSN — must use postgresql+asyncpg:// scheme
DATABASE_URL=postgresql+asyncpg://worldzero:changeme@localhost:5432/worldzero

# Random 64-char string — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-random-secret-key

# Google OAuth credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# "development" or "production"
ENVIRONMENT=development

# Filesystem path where uploaded media is stored
MEDIA_ROOT=/media

# Base URL used to build public media URLs
MEDIA_BASE_URL=http://localhost:8000/media
